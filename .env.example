# PostgreSQL
POSTGRES_DB=myqaweb
POSTGRES_USER=myqaweb
POSTGRES_PASSWORD=admin

# Spring DataSource (used by backend service in docker-compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/myqaweb
SPRING_DATASOURCE_USERNAME=myqaweb
SPRING_DATASOURCE_PASSWORD=admin

# Spring AI / Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Spring AI / OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# Frontend Vite proxy target (used in local dev, optional)
VITE_API_BASE_URL=http://localhost:8080
