{
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(cd backend && ./gradlew:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/claude-slack-notify.sh stop",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/claude-slack-notify.sh notification",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
